# ==========================================
# LEVERIXPRO: ENVIRONMENT VARIABLES EXAMPLE
# ==========================================
# 1. Copy this file: cp .env.local.example .env.local
# 2. Fill in your actual API keys below.
# 3. NEVER commit .env.local to GitHub (it is in .gitignore).

# 1. AI AGENT BRAIN (xAI / Grok)
# Get your key at: https://console.x.ai/
XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. HELIUS RPC (Institutional Solana Node — highly recommended)
# Sign up at: https://helius.dev/
NEXT_PUBLIC_HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# 3. SUPABASE (Social Feeds, Orders & CopyTrade Database)
# Create a project at: https://supabase.com/
# Then run supabase_schema.sql in your SQL Editor.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-public-key
