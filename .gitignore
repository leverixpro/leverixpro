# ─── Dependencies ───────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── GitHub Push Script (contains PAT — NEVER upload) ───────────────
push.ps1

# ─── Next.js Build Output ───────────────────────────────────────────
.next/
out/
build/

# ─── Environment & Secrets ──────────────────────────────────────────
.env
.env.*
!.env.local.example

# ─── AI Agent Internal Files (not for public) ───────────────────────
AGENTS.md
CLAUDE.md

# ─── VPS / Railway Deployment Config ────────────────────────────────
railway.toml
.railwayignore
nixpacks.toml

# ─── Server Worker (backend-only runtime) ───────────────────────────
server/

# ─── Smart Contracts (separate repo recommended) ────────────────────
smart_contract/

# ─── Scripts (infra / deploy scripts, not source) ───────────────────
scripts/

# ─── TypeScript Build Artifacts ─────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Package Lock (optional — remove if you want reproducible builds)
package-lock.json

# ─── Misc / OS Files ────────────────────────────────────────────────
.DS_Store
*.pem
*.key
Thumbs.db

# ─── Logs ───────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ─── Vercel ─────────────────────────────────────────────────────────
.vercel

# ─── IDE / Editor ───────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
